generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(cuid())
  nome     String
  email    String   @unique
  imagem   String?
  metas    Meta[]
  criadoEm DateTime @default(now()) @map("criado_em")

  @@map("users")
}

model Meta {
  id           String       @id @default(cuid())
  userId       String       @map("user_id")
  user         User         @relation(fields: [userId], references: [id])
  tipoTrabalho String       @map("tipo_trabalho")
  valorMeta    Decimal      @map("valor_meta") @db.Decimal(10, 2)
  diasTrabalho Int          @map("dias_trabalho")
  metaDiaria   Decimal      @map("meta_diaria") @db.Decimal(10, 2)
  mes          Int
  ano          Int
  lancamentos  Lancamento[]
  criadoEm     DateTime     @default(now()) @map("criado_em")

  @@map("metas")
}

model Lancamento {
  id          String   @id @default(cuid())
  metaId      String   @map("meta_id")
  meta        Meta     @relation(fields: [metaId], references: [id])
  valorBruto  Decimal  @map("valor_bruto") @db.Decimal(10, 2)
  totalGastos Decimal  @map("total_gastos") @db.Decimal(10, 2)
  lucro       Decimal  @db.Decimal(10, 2)
  bateuMeta   Boolean  @map("bateu_meta")
  gastos      Gasto[]
  data        DateTime @default(now())

  @@map("lancamentos")
}

model Gasto {
  id           String     @id @default(cuid())
  lancamentoId String     @map("lancamento_id")
  lancamento   Lancamento @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)
  valor        Decimal  @db.Decimal(10, 2)
  categoria    String

  @@map("gastos")
}
